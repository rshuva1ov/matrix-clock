{
  "productName": "Matrix Clock",
  "version": "0.1.0",
  "identifier": "com.example.matrixclock",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Matrix Clock",
        "fullscreen": false,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32.png",
      "icons/50.png",
      "icons/144.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
